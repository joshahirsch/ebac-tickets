# ---------------------------------------------------------------------------
# EBAC Projects — environment variables
# Copy to .env.local (Next.js) / .env (Prisma CLI) and fill in real values.
# ---------------------------------------------------------------------------

# --- Database (Supabase Postgres) ---
# Pooled connection (used by the app at runtime). Port 6543, pgbouncer.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrate/seed). Port 5432.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth / API ---
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
# Public browser key. Supply EITHER the legacy anon key OR the new publishable
# key (sb_publishable_...). The app reads whichever of these two is set.
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# Server-only secret. Legacy service_role key OR the new secret key
# (sb_secret_...). NEVER expose to the client. Not required for Phases 1-3.
SUPABASE_SERVICE_ROLE_KEY="<service-role-or-sb_secret-key>"

# --- Storage ---
# Bucket name used for ticket attachments (create in Supabase Storage).
SUPABASE_STORAGE_BUCKET="ticket-attachments"

# --- App config ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Email of the first user who should be promoted to ADMIN on bootstrap.
BOOTSTRAP_ADMIN_EMAIL="admin@ebac.org"

# Secret guarding the scheduled due-soon endpoint (/api/cron/due-soon).
# Generate any long random string. Vercel Cron sends it as a Bearer token.
CRON_SECRET="<random-string>"

# --- Google Calendar personal sync (Phase 2A) ---
# Create an OAuth 2.0 Web client in Google Cloud Console → APIs & Services → Credentials.
# Enable the Google Calendar API. Authorized redirect URI must match GOOGLE_REDIRECT_URI.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/integrations/google-calendar/callback when unset.
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google-calendar/callback"
# 64-char hex or any long secret (hashed to AES-256 key) used to encrypt OAuth tokens at rest.
# GOOGLE_TOKEN_ENCRYPTION_KEY=""

# --- AI (optional, Phase future) ---
# Leave unset to keep AI features as no-op placeholders.
# OPENAI_API_KEY=""
# AI_PROVIDER="openai"
